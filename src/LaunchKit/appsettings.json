        "Description": "Bitbucket PR reports",
        "WorkingDirectory": "%USERPROFILE%\\Desktop\\MyApps\\BBRepoList"
      },
      {
        "Name": "BBDevPulse",
        "Path": "%USERPROFILE%\\Desktop\\MyApps\\BBDevPulse\\BBDevPulse.exe",
        "Description": "Developer Code reports",
        "WorkingDirectory": "%USERPROFILE%\\Desktop\\MyApps\\BBDevPulse"
      }
